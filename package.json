{
  "name": "monad-strike",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "MonadStrike — On-Chain CS Economy Game on Monad Testnet",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
